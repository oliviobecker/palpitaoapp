# ---------------------------------------------------------------------------
# Root environment file for docker-compose (PostgreSQL).
# Copy to ".env" and adjust as needed:  cp .env.example .env
# ---------------------------------------------------------------------------
POSTGRES_USER=palpitao
POSTGRES_PASSWORD=palpitao
POSTGRES_DB=palpitao
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# External fixture provider (round-by-period import).
# The backend binds the "Fixtures" section; override any field with the
# Fixtures__<Field> environment variable (double underscore). Examples below.
# Provider: "TheSportsDb" (free, current-season, default), "ApiFootball"
# (reliable but the free tier has no current season) or "OneFootball" (best-effort).
# Set Fixtures__EnableExternalFixtureImport=false to keep only the manual flow
# (the "Search fixtures" button is disabled and the API returns a clear error).
# Keep real API keys out of source control — set them here / in user-secrets.
# ---------------------------------------------------------------------------
Fixtures__Provider=OneFootball
Fixtures__TheSportsDbKey=3
# Fixtures__ApiKey=your-api-football-key   # only if Provider=ApiFootball
Fixtures__TimeoutSeconds=15
Fixtures__EnableExternalFixtureImport=true

# ---------------------------------------------------------------------------
# Match results provider (admin "refresh results" + temporary standings).
# "Manual" (default): no external fetch — results come from manual entry and
# the refresh just recomputes the temporary standings.
# "ConfiguredWebsite": set Enabled=true + a BaseUrl to fetch results externally.
# ---------------------------------------------------------------------------
ResultsProvider__Provider=Manual
ResultsProvider__Enabled=false
# ResultsProvider__BaseUrl=
ResultsProvider__TimeoutSeconds=15
