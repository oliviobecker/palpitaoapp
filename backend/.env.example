# ---------------------------------------------------------------------------
# Backend environment variables (optional overrides).
# .NET reads these on top of appsettings*.json. The double underscore maps to
# nested config keys (ConnectionStrings:DefaultConnection).
# Copy to ".env" if your tooling loads it, or export them in your shell.
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL connection used by EF Core. Must match docker-compose / your DB.
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=palpitao;Username=palpitao;Password=palpitao

# JWT settings (used in a later phase — placeholders for now).
Jwt__Issuer=palpitao
Jwt__Audience=palpitao
Jwt__Key=change-me-to-a-long-random-secret-key

# Sentry monitoring. Keep SENTRY_DSN empty to disable event delivery.
SENTRY_DSN=
SENTRY_ENVIRONMENT=Development
SENTRY_RELEASE=palpitao-england-backend@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_DEBUG=false
