{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Sentry": {
    "Dsn": "",
    "Environment": "Development",
    "Release": "palpitao-backend@1.0.0",
    "TracesSampleRate": 0.0,
    "Debug": false,
    "SendDefaultPii": false,
    "MinimumBreadcrumbLevel": "Information",
    "MinimumEventLevel": "Error"
  },
  "AllowedHosts": "*",
  "Cors": {
    "_comment": "Trusted browser origins for the deployed frontend (used outside Development). Set via Cors__AllowedOrigins__0, Cors__AllowedOrigins__1, ... e.g. https://app.example.com",
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=palpitao;Username=palpitao;Password=palpitao"
  },
  "Jwt": {
    "Issuer": "palpitao",
    "Audience": "palpitao",
    "Key": "dev-only-change-me-to-a-long-random-secret-of-at-least-32-bytes",
    "ExpiresHours": 12
  },
  "RateLimiting": {
    "_comment": "Per-client-IP throttle for the unauthenticated auth endpoints (login/register/create-group/refresh).",
    "Auth": {
      "PermitLimit": 20,
      "WindowSeconds": 60
    }
  },
  "ResultsProvider": {
    "Provider": "OneFootball",
    "BaseUrl": "",
    "Enabled": true,
    "TimeoutSeconds": 15
  },
  "ResultsRefresh": {
    "Enabled": true,
    "IntervalMinutes": 5,
    "OnlyActiveRounds": true
  },
  "Fixtures": {
    "Provider": "OneFootball",
    "OneFootballApiBaseUrl": "https://api.onefootball.com/web-experience/en/competition",
    "FixtureDownloadBaseUrl": "https://fixturedownload.com/feed/json",
    "BaseUrl": "https://onefootball.com",
    "ApiFootballBaseUrl": "https://v3.football.api-sports.io",
    "ApiKey": "",
    "TheSportsDbBaseUrl": "https://www.thesportsdb.com/api/v1/json",
    "TheSportsDbKey": "3",
    "TimeoutSeconds": 15,
    "EnableExternalFixtureImport": true
  }
}
