{
  "name": "palpitao",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "generate:version": "node scripts/generate-version.mjs",
    "prestart": "node scripts/generate-version.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/generate-version.mjs",
    "build": "ng build",
    "prewatch": "node scripts/generate-version.mjs",
    "watch": "ng build --watch --configuration development",
    "pretest": "node scripts/generate-version.mjs",
    "test": "ng test",
    "e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss}\" \"e2e/**/*.ts\" \"*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss}\" \"e2e/**/*.ts\" \"*.{ts,json}\""
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.15",
    "@angular/cli": "^21.2.15",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.61.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
